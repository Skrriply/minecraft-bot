# Discord bot token
# https://discord.com/developers/applications
DISCORD_TOKEN=token

# Bot owner ID
# https://support.discord.com/hc/en-us/articles/206346498-Where-can-I-find-my-User-Server-Message-ID
DISCORD_OWNER_ID=12345

# ID of the channel where the bot will write
DISCORD_CHANNEL_ID=12345

# Pterodactyl Panel URL
PTERODACTYL_URL=https://ptero.example.com

# Pterodactyl Client API key
PTERODACTYL_API_KEY=api_key

# ID of the server that the bot will manage
PTERODACTYL_SERVER_ID=server_id

# Svitlo.live API URL
OUTAGE_API_URL=https://svitlo.example.com

# Region and group
REGION_CPU=kyiv
GROUP_ID=1.1

# Other settings
SHUTDOWN_OFFSET_MINUTES=10
WARN_OFFSET_MINUTES=5
STARTUP_TIMEOUT_SECONDS=300
STOP_TIMEOUT_SECONDS=300
TIMEZONE=Europe/Kyiv
